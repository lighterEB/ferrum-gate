		"@types/node": "^24.12.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/coverage-v8": "4.1.2",
		"jsdom": "29.0.1",
		"msw": "2.12.14",
		"playwright": "1.59.1",
		"typescript": "~5.9.3",
		"vite": "^8.0.1",
		"vitest": "4.1.2"
	}
